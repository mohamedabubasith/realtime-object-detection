# Copy to .env and tweak as needed. All values are optional (sane defaults).

# --- Model ---
# Default uses an ONNX export of YOLO26n for fast CPU inference (run.sh creates
# models/yolo26n.onnx automatically; falls back to yolo26n.pt if missing).
# Alternatives: yolo11n.onnx / yolo11n.pt (older, fully mature) or yolo26n.pt.
MODEL_PATH=models/yolo26n.onnx

# Which COCO classes to count (comma separated). The model detects all 80
# classes; this just selects which to report. Default: car (the primary use
# case). Extend with any COCO names, e.g. TARGET_CLASSES=car,truck,bus,person
TARGET_CLASSES=car

# --- Detection tuning ---
# Minimum confidence (0-1) for a detection to count.
CONF_THRESHOLD=0.35
# Non-max-suppression IoU threshold.
IOU_THRESHOLD=0.45
# Inference size. 416 = good balance; 320 = faster; 640 = more accurate.
# If you use an ONNX model, re-export at this size (scripts/export_model.py).
IMGSZ=416
# Max detections kept per frame.
MAX_DET=100
# Ignore boxes smaller than this fraction of the frame (0 = off). e.g. 0.0008
MIN_BOX_AREA_RATIO=0.0

# --- Performance (tuned for 2-core / 4GB CPU) ---
PROCESS_EVERY_N=2
MAX_FRAME_WIDTH=960
# Live-stream jitter buffer (seconds). Prevents the video freezing every few
# seconds while the next YouTube/HLS segment is fetched. Higher = smoother but
# more delay behind "live" + more RAM. Lower (e.g. 1.0) = closer to live.
LIVE_BUFFER_SECONDS=2.0
STREAM_FPS=15
JPEG_QUALITY=70
MAX_SESSIONS=2
NUM_THREADS=2

# --- Server ---
HOST=0.0.0.0
PORT=8000
# CORS allowed origins (comma separated). "*" is fine for local dev.
CORS_ORIGINS=*
# How many recent detection-log entries to keep per session.
LOG_SIZE=100

# --- YouTube / stream sources ---
# YouTube often blocks cloud/datacenter IPs (e.g. Hugging Face Spaces). To make
# YouTube links work from a server, export your browser cookies to a
# Netscape-format cookies.txt and point this at it. Leave empty otherwise.
# YTDLP_COOKIES=/path/to/cookies.txt
